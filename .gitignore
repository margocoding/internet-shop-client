```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# Testing
.mypy_cache/
.pytest_cache/

# Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled JavaScript
*.min.js

# TypeScript
*.tsbuildinfo
```